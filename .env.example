# =============================================================================
# Greenback Finance Intelligence Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the required values:
#   cp .env.example .env
#
# Environment variables override settings in config/config.yaml.
# Only uncomment and set the variables you need to override.
# =============================================================================

# -----------------------------------------------------------------------------
# QGenie / LLM Settings (REQUIRED)
# -----------------------------------------------------------------------------
# Your QGenie API key for LLM access
QGENIE_API_KEY=your-api-key-here

# QGenie chat endpoint URL
QGENIE_CHAT_ENDPOINT=https://qgenie-chat.qualcomm.com

# Base model name (default: qgenie)
# QGENIE_MODEL_NAME=qgenie

# Coding model used by the SQL and code-generation agents
# CODING_MODEL_NAME=anthropic::claude-4-sonnet

# Reasoning model used by the orchestration/intent agents
# REASONING_MODEL_NAME=azure::gpt-5.2

# -----------------------------------------------------------------------------
# Model-Specific Overrides (Optional)
# -----------------------------------------------------------------------------
# ANTHROPIC_MODEL=anthropic::claude-4-sonnet
# AZURE_MODEL=azure::gpt-4.1
# GEMINI_MODEL=vertexai::gemini-2.5-pro

# -----------------------------------------------------------------------------
# PostgreSQL Database (REQUIRED for production)
# -----------------------------------------------------------------------------
# Full SQLAlchemy connection string
POSTGRES_CONNECTION=postgresql+psycopg2://postgres:postgres@localhost/cnss_opex_db

# Individual connection parameters (used by CBN Resource Planner)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB_NAME=cnss_opex_db
POSTGRES_USER=postgres
POSTGRES_PWD=postgres

# Admin credentials (used for bootstrap/setup scripts)
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PWD=postgres

# PGVector / LangChain table names
POSTGRES_COLLECTION=cnss_opex_db
POSTGRES_COLLECTION_TABLENAME=langchain_pg_collection
POSTGRES_EMBEDDING_TABLENAME=langchain_pg_embedding
POSTGRES_STORE_NAME=cnss_opex_db

# -----------------------------------------------------------------------------
# Paths (Optional — defaults are usually fine)
# -----------------------------------------------------------------------------
# SOURCE_PATH=data/excel_files
# SAVE_PATH=out
# OUT_PATH=out
# OUTPUT_JSONL_PATH=out/output.jsonl

# Comma-separated list of Excel files to ingest
# EXCEL_FILE_NAMES=FY25 Q4 WIN Opex_data.xlsx, FY25 Q3 WIN Opex_data.xlsx

# -----------------------------------------------------------------------------
# Streamlit / Application Settings (Optional)
# -----------------------------------------------------------------------------
# STREAMLIT_PORT=8502
# LOG_LEVEL=INFO

# Feedback recipient email
# FEEDBACK_EMAIL_ID=your-email@company.com

# -----------------------------------------------------------------------------
# Database Type (Optional — defaults to Postgres)
# -----------------------------------------------------------------------------
# Set to "SQLite" to use local SQLite instead of PostgreSQL
# DATABASE_NAME=Postgres
